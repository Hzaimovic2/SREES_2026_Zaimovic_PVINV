Header:
	newTab = false
	drawPlots = true
end
Model [name="Solar inverter visualization"]:
Plots [backColor=auto]:
	linePlot [xLabel="Time [s]" yLabel="Power [MW/MVAr]" name="PV inverter dynamic response" legend=true]:
		@x << t
		@y << p_ac [colorL=darkGreen colorD=green width=2 name="P ac"]
		@y << q_ac [colorL=darkBlue colorD=cyan width=2 name="Q ac"]
		@y << p_dc [colorL=darkRed colorD=red width=2 name="P dc"]
	end
end
